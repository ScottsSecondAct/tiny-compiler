fn abs_val(x: int) -> int {
    if (x < 0) {
        return -x;
    }
    return x;
}

fn clamp(val: int, lo: int, hi: int) -> int {
    if (val < lo) { return lo; }
    if (val > hi) { return hi; }
    return val;
}

print(abs_val(-7));
print(abs_val(3));
print(abs_val(0));
print(clamp(5, 1, 10));
print(clamp(-3, 1, 10));
print(clamp(15, 1, 10));
